# Ollama
# OLLAMA_MODEL_NAME 을 지정하면 LLM_BASE_MODEL / LLM_QUANTIZATION 조합 규칙을 무시하고 그대로 사용한다.
# 비워두면 "${LLM_BASE_MODEL}-instruct-${LLM_QUANTIZATION}" 형식으로 조합된다 (기본 동작).
OLLAMA_MODEL_NAME=exaone3.5:7.8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=60

# LLM 양자화 수준 선택 (사용자 런타임 전환 대상)
# 허용: q4_K_M, q8_0, fp16
# fp16 = 양자화 없음(원본 정밀도 / 약 15GB / 최고사양 권장)
LLM_BASE_MODEL=exaone3.5:7.8b
LLM_QUANTIZATION=q4_K_M

# Docker Compose 실행 모드 (cpu 또는 gpu)
# cpu : GPU 감지 차단, CPU로만 추론
# gpu : NVIDIA GPU 사용 (호스트에 NVIDIA Container Toolkit 필요)
COMPOSE_PROFILES=cpu

# Embedding
EMBEDDING_DEVICE=auto

# ChromaDB
CHROMA_COLLECTION=contract_kb

# Detection
RULE_SCORE_THRESHOLD=0.3
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.5
