# 기본: Git이 자동 감지 + OS별 체크아웃 줄바꿈 정규화
* text=auto

# Windows 전용 스크립트 — 항상 CRLF로 체크아웃
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Unix 전용 스크립트 — 항상 LF로 체크아웃
*.sh     text eol=lf

# 바이너리 — 변환 금지
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.sqlite3 binary
*.pkl    binary